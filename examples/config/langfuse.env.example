# Langfuse + OpenTelemetry for Logan
# Author: Yuval Avidani (YUV.AI) - https://yuv.ai
#
# 1) Create a Langfuse project → Settings → API Keys
# 2) Copy public + secret keys
# 3) source this file (with real values) before `logan`
#
# Cloud EU example base: https://cloud.langfuse.com
# Cloud US example base: https://us.cloud.langfuse.com
# Self-host: your origin

export OTEL_SERVICE_NAME="logan-cli"
export OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"

# Langfuse OTEL endpoint (public OTLP)
export OTEL_EXPORTER_OTLP_ENDPOINT="${LANGFUSE_HOST:-https://cloud.langfuse.com}/api/public/otel"

# Basic auth = base64(public:secret)
#   printf '%s' "pk-lf-...:sk-lf-..." | base64
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic ${LANGFUSE_OTLP_BASIC_AUTH}"

# Optional: also send models via LiteLLM (logs + budgets there too)
# export LITELLM_API_KEY=sk-...
# and use examples/config/observability.toml [model.via-litellm]

# Verify: run a short headless turn, then check Langfuse Traces UI
#   logan --route auto -p "ping" --output-format json
